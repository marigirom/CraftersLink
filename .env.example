# CraftersLink Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================
# GENERAL SETTINGS
# ============================================
DEBUG=True
ENVIRONMENT=development

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_NAME=crafterslink
DB_USER=postgres
DB_PASSWORD=postgres123
DB_HOST=db
DB_PORT=5432

# ============================================
# DJANGO SETTINGS
# ============================================
# Generate a secure key for production: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=django-insecure-dev-key-change-in-production

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend

# Comma-separated list of CORS allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# API base URL for frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ============================================
# IBM CLOUD OBJECT STORAGE (Optional)
# ============================================
# Leave empty to use local file storage
IBM_COS_ENDPOINT=
IBM_COS_API_KEY=
IBM_COS_INSTANCE_ID=
IBM_COS_BUCKET_NAME=crafterslink-media
IBM_COS_AUTH_ENDPOINT=https://iam.cloud.ibm.com/identity/token
IBM_COS_PUBLIC_ENDPOINT=

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@crafterslink.com

# ============================================
# SECURITY SETTINGS (Production)
# ============================================
# Set to True in production
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO

# ============================================
# SUPERUSER CREDENTIALS (Auto-created on first run)
# ============================================
DJANGO_SUPERUSER_EMAIL=admin@crafterslink.com
DJANGO_SUPERUSER_PASSWORD=admin123

# Made with Bob